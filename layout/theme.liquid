<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>{{ page_title }}</title>
  <link rel="canonical" href="{{ canonical_url }}">
  <link rel="icon" type="image/png" href="{{ 'favicon.png' | asset_url }}">

  {{ content_for_header }}

  <!-- Inject Store Configuration into window object for React storefront -->
  <script>
    window.ShopifyStorefrontConfig = {
      domain: window.location.hostname,
      token: "4fb5c5e0cba28f099773e3d20c3393dc" // Exposes your storefront token
    };
    
    window.SupabaseConfig = {
      url: "https://your-supabase-project.supabase.co", // Replace with your Supabase URL
      anonKey: "your-supabase-anon-key" // Replace with your Supabase Anon Key
    };

    window.ShopifyAssets = {
      logoUrl: "{{ 'logo.png' | asset_url }}",
      event1Url: "{{ 'event1.jpg' | asset_url }}",
      event2Url: "{{ 'event2.jpg' | asset_url }}",
      event3Url: "{{ 'event3.jpg' | asset_url }}",
      introBgUrl: "{{ 'intro-bg.jpg' | asset_url }}",
      introBgVideoUrl: "{{ 'Zoro.mp4' | asset_url }}",
      logoAnimVideoUrl: "{{ 'cardpirates-logo-kleiner.mp4' | asset_url }}",
      logoSchriftUrl: "{{ 'cardpirates-schrift-weiss.png' | asset_url }}"
    };
  </script>

  <!-- Load Compiled React App Tailwind Styles -->
  {{ 'theme-app.css' | asset_url | stylesheet_tag }}
</head>
<body class="bg-[#0b0f19] text-slate-100 min-h-screen">

  <!-- Main Shopify Template Output -->
  {{ content_for_layout }}

  <!-- Load Compiled React App JavaScript Bundle -->
  <script src="{{ 'theme-app.js' | asset_url }}" type="module" defer="defer"></script>

</body>
</html>
