<!DOCTYPE html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
  <title>{{ page_title }}</title>
  <link rel="canonical" href="{{ canonical_url }}">

  {{ content_for_header }}

  <!-- Inject Store Configuration into window object for React storefront -->
  <script>
    window.ShopifyStorefrontConfig = {
      domain: window.location.hostname,
      token: "YOUR_STOREFRONT_TOKEN" // Exposes your storefront token
    };
    
    window.SupabaseConfig = {
      url: "https://your-supabase-project.supabase.co", // Replace with your Supabase URL
      anonKey: "your-supabase-anon-key" // Replace with your Supabase Anon Key
    };
  </script>

  <!-- Load Compiled React App Tailwind Styles -->
  {{ 'theme-app.css' | asset_url | stylesheet_tag }}
</head>
<body class="bg-[#0b0f19] text-slate-100 min-h-screen">

  <!-- Main Shopify Template Output -->
  {{ content_for_layout }}

  <!-- Load Compiled React App JavaScript Bundle -->
  {{ 'theme-app.js' | asset_url | script_tag }}

</body>
</html>
